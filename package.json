{
  "name": "code-quality-analyzer",
  "version": "1.0.0",
  "description": "CLI tool for analyzing code quality with industry-standard software metrics",
  "main": "dist/index.js",
  "bin": {
    "cqa": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "keywords": [
    "code-quality",
    "static-analysis",
    "complexity",
    "metrics",
    "cli"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/redoh/code-quality-analyzer.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "typescript": "^5.3.0"
  }
}
